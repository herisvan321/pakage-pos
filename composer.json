{
    "name": "herisvanhendra/pos",
    "description": "Aplikasi Point of Sales dengan Laravel",
    "autoload": {
        "psr-4": {
            "Herisvanhendra\\Pos\\": "src/"
        }
    },
    "authors": [
        {
            "name": "herisvan"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Herisvanhendra\\Pos\\PosServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

